# =========================================================================
# Backend Environment Configurations
# =========================================================================

# Database Connection (Adjust coordinates for local vs docker)
# For local postgres instance: postgresql://username:password@localhost:5432/db_name
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/analytics

# Security Secret Key (Generate a secure random hex key in production: openssl rand -hex 32)
SECRET_KEY=09d25e094faa6ca2556c818166b7a9563b93f7099f6f0f4caa6cf63b88e8d3e7
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Demo Seeding Flag (Set to "false" once initial seed data is loaded)
SEED_DEMO_DATA=true

# =========================================================================
# Frontend Environment Configurations
# =========================================================================
# (Note: Vite config proxies local requests to backend. No absolute URI required locally)
VITE_API_URL=/api
